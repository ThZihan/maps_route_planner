# ============================================
# SERVER ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control
# ============================================

# Application Environment
NODE_ENV=production

# Port Configuration
BACKEND_PORT=3000
FRONTEND_PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# CORS Origin
# Set to your Cloudflare domain in production, e.g., https://maps.kalobiral.com.bd
CORS_ORIGIN=*

# Database Configuration
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD_NOW

# OSRM Configuration
# Using public API by default to save memory
# To use local OSRM, uncomment the osrm-backend service in docker-compose.server.yml
# and change this to: OSRM_URL=http://osrm-backend:5000
OSRM_URL=https://router.project-osrm.org

# Nominatim Configuration
# Local Nominatim service (running in container)
NOMINATIM_URL=http://nominatim:8080

# Redis Configuration
REDIS_URL=redis://redis:6379

# PostgreSQL Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=mapsdb
DB_USER=mapsuser

# ============================================
# SECURITY NOTES
# ============================================
# 1. Change DB_PASSWORD to a strong, unique password
# 2. Set CORS_ORIGIN to your actual domain in production
# 3. All services are bound to 127.0.0.1 for security
# 4. Only frontend port 3001 is accessible via Cloudflare Tunnel
# ============================================

# ============================================
# MEMORY LIMITS (Server Configuration)
# ============================================
# Frontend: 64M (actual usage ~20MB)
# Backend: 128M (actual usage ~90MB)
# Nominatim: 512M (actual usage ~450MB)
# PostgreSQL: ~20-30MB
# Redis: ~5-10MB
# Docker Engine: ~100MB
# Total: ~800MB (well within 2GB limit)
# ============================================
